<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.travel.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.travel.entity.User">
        <id     column="user_id"     property="userId"/>
        <result column="username"    property="username"/>
        <result column="password"    property="password"/>
        <result column="nickname"    property="nickname"/>
        <result column="phone"       property="phone"/>
        <result column="email"       property="email"/>
        <result column="avatar"      property="avatar"/>
        <result column="gender"      property="gender"/>
        <result column="birthday"    property="birthday"/>
        <result column="user_type"   property="userType"/>
        <result column="status"      property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="BaseColumns">
        user_id, username, password, nickname, phone, email, avatar,
        gender, birthday, user_type, status, create_time, update_time
    </sql>

    <!-- 根据用户名查询 -->
    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM t_user
        WHERE username = #{username}
    </select>

    <!-- 根据手机号查询 -->
    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM t_user
        WHERE phone = #{phone}
    </select>

    <!-- 根据 ID 查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM t_user
        WHERE user_id = #{userId}
    </select>

    <!-- 插入用户 -->
    <insert id="insert" parameterType="com.travel.entity.User"
            useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO t_user (username, password, nickname, phone, email, avatar,
                            gender, birthday, user_type, status)
        VALUES (#{username}, #{password}, #{nickname}, #{phone}, #{email}, #{avatar},
                #{gender}, #{birthday}, 1, 1)
    </insert>

    <!-- 更新用户信息（管理员用，包含 status/userType） -->
    <update id="updateById" parameterType="com.travel.entity.User">
        UPDATE t_user
        <set>
            update_time = NOW(),
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthday != null">birthday = #{birthday},</if>
            <if test="status != null">status = #{status},</if>
            <if test="userType != null">user_type = #{userType},</if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <!-- 更新用户个人资料（仅安全字段，防止越权修改 status/userType） -->
    <update id="updateUserProfile" parameterType="com.travel.entity.User">
        UPDATE t_user
        <set>
            update_time = NOW(),
            <if test="nickname != null">nickname = #{nickname},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthday != null">birthday = #{birthday},</if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <!-- 检查用户名是否存在 -->
    <select id="countByUsername" resultType="int">
        SELECT COUNT(*) FROM t_user WHERE username = #{username}
    </select>

    <!-- 检查手机号是否存在 -->
    <select id="countByPhone" resultType="int">
        SELECT COUNT(*) FROM t_user WHERE phone = #{phone}
    </select>

    <!-- 查询所有用户 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM t_user ORDER BY create_time DESC
    </select>

    <!-- 分页查询用户 -->
    <select id="selectAllPaged" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/> FROM t_user
        <where>
            <if test="keyword != null and keyword != ''">
                AND (username LIKE CONCAT('%',#{keyword},'%') OR nickname LIKE CONCAT('%',#{keyword},'%') OR phone LIKE CONCAT('%',#{keyword},'%'))
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>
    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM t_user
        <where>
            <if test="keyword != null and keyword != ''">
                AND (username LIKE CONCAT('%',#{keyword},'%') OR nickname LIKE CONCAT('%',#{keyword},'%') OR phone LIKE CONCAT('%',#{keyword},'%'))
            </if>
        </where>
    </select>

    <!-- 删除用户 -->
    <delete id="deleteById">
        DELETE FROM t_user WHERE user_id = #{userId}
    </delete>

</mapper>
